{
  "name": "claude-open",
  "version": "0.1.0",
  "private": true,
  "description": "Run the official signed Claude Desktop in an isolated Windows profile with a user-supplied compatible API gateway.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "node --test",
    "test:integration": "node --test \"tests/integration/*.test.js\"",
    "verify:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-release.ps1",
    "verify:release:selftest": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-release.selftest.ps1",
    "verify:release:full": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-release.ps1 -IncludeGitHistory",
    "build:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Build-Release.ps1"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
